{
  "repo": "packet-trace-log-grid",
  "language": "Scala",
  "category": "Observability",
  "goal": "Package a Scala local lab for log analysis with transition tables, invalid-transition tests, and documented operating limits.",
  "weights": {
    "signal": 3,
    "slack": 1,
    "confidence": 1,
    "drag": 2
  },
  "thresholds": {
    "ship": 202,
    "watch": 129
  },
  "properties": [
    "raising signal cannot reduce score",
    "raising drag cannot improve score",
    "lane labels must match configured thresholds",
    "golden fixture ids must remain unique"
  ],
  "fixture_files": [
    "fixtures/golden/scoreboard.csv",
    "fixtures/golden/lane-matrix.csv",
    "fixtures/fuzz/mutations.csv",
    "fixtures/fuzz/boundary-cases.jsonl"
  ]
}
